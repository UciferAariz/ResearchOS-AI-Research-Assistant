ENVIRONMENT=development
CORS_ALLOW_ORIGINS=["http://localhost:3000"]

# arXiv
ARXIV_API_BASE_URL=https://export.arxiv.org/api/query
ARXIV_REQUEST_TIMEOUT_SECONDS=15.0
SEARCH_CACHE_TTL_SECONDS=300
SEARCH_CACHE_MAX_SIZE=256

# Fireworks AI (wired starting Phase 3)
FIREWORKS_API_KEY=
# Default: Gemma via Fireworks (bonus hackathon challenge track).
FIREWORKS_MODEL=accounts/fireworks/models/gemma2-9b-it
# Fallback if Gemma's structured-JSON/citation formatting proves unreliable in Phase 3:
# FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
