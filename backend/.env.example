ENVIRONMENT=development
CORS_ALLOW_ORIGINS=["http://localhost:3000"]

# arXiv
ARXIV_API_BASE_URL=https://export.arxiv.org/api/query
ARXIV_REQUEST_TIMEOUT_SECONDS=15.0
SEARCH_CACHE_TTL_SECONDS=300
SEARCH_CACHE_MAX_SIZE=256

# PubMed (NCBI E-utilities)
PUBMED_API_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
PUBMED_REQUEST_TIMEOUT_SECONDS=15.0
# Optional — without a key NCBI rate-limits to 3 req/s; with one, 10 req/s.
# Get one at https://www.ncbi.nlm.nih.gov/account/settings/
PUBMED_API_KEY=

# Fireworks AI
FIREWORKS_API_KEY=
# Optional override — unset uses the serverless default in settings.py (deepseek-v4-pro).
# Gemma bonus challenge: Gemma requires a paid *dedicated deployment* on Fireworks
# (billed per GPU-hour). Create it in the Fireworks dashboard, then set this to the
# deployed model id (accounts/<your-account>/deployedModels/<name>) — no code change
# needed — and delete the deployment afterward so it stops billing.
# FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_REQUEST_TIMEOUT_SECONDS=60.0
SUMMARY_CACHE_TTL_SECONDS=3600
SUMMARY_CACHE_MAX_SIZE=256
