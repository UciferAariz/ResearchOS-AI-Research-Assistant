ENVIRONMENT=development
CORS_ALLOW_ORIGINS=["http://localhost:3000"]

# arXiv
ARXIV_API_BASE_URL=https://export.arxiv.org/api/query
ARXIV_REQUEST_TIMEOUT_SECONDS=15.0
SEARCH_CACHE_TTL_SECONDS=300
SEARCH_CACHE_MAX_SIZE=256

# Fireworks AI (wired starting Phase 3)
FIREWORKS_API_KEY=
# Default: a serverless (pay-per-token) reasoning model for development — cheap,
# no deployment to manage. Confirm the exact id is in your account's catalog via:
#   curl -s -H "Authorization: Bearer $FIREWORKS_API_KEY" \
#     https://api.fireworks.ai/inference/v1/models | python -m json.tool | grep '"id"'
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-pro
#
# GEMMA BONUS CHALLENGE: Gemma (e.g. "Gemma 4 26B A4B IT") is NOT serverless on
# Fireworks — it requires a paid *dedicated deployment* (billed per GPU-hour while
# running). For the final demo, create the deployment in the Fireworks dashboard,
# then set FIREWORKS_MODEL to the deployed model id it gives you (looks like
# accounts/<your-account>/deployedModels/<name>) — no code change needed — and
# DELETE the deployment afterward so it stops charging the $50 credit.
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_REQUEST_TIMEOUT_SECONDS=60.0
SUMMARY_CACHE_TTL_SECONDS=3600
SUMMARY_CACHE_MAX_SIZE=256
